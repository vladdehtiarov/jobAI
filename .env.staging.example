# Copy to deployment environment variables or .env.staging.local
APP_ENV=staging

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-staging-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

BRINGDATA_API_KEY=your-staging-bringdata-api-key
APIFY_API_TOKEN=your-staging-apify-token

UNIPILE_API_KEY=your-staging-unipile-api-key
